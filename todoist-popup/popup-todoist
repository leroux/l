#!/bin/zsh

set -euo pipefail

app_name="${TODOIST_APP_NAME:-Todoist}"

# Query the private Focus intent handler because current macOS versions no
# longer expose a stable shell-readable Do Not Disturb flag.
dnd_state() {
  if [[ ! -x /usr/bin/swift ]]; then
    print -- "unknown"
    return 0
  fi

  /usr/bin/swift - 2>/dev/null <<'SWIFT'
import Foundation
import Intents
import Dispatch
import ObjectiveC.runtime
import Darwin

let bundleBinary = "/System/Library/PrivateFrameworks/DoNotDisturb.framework/PlugIns/DoNotDisturbIntents.appex/Contents/MacOS/DoNotDisturbIntents"

guard dlopen(bundleBinary, RTLD_NOW) != nil else {
  print("unknown")
  exit(0)
}

guard
  let intentClass = NSClassFromString("DNDGetFocusStateIntent") as? NSObject.Type,
  let handlerClass = NSClassFromString("DNDGetFocusStateIntentHandler") as? NSObject.Type
else {
  print("unknown")
  exit(0)
}

let intent = intentClass.init()
let focus = INObject(identifier: "com.apple.donotdisturb.mode.default", display: "Do Not Disturb")
intent.setValue(focus, forKey: "focus")

let handler = handlerClass.init()
let selector = sel_registerName("handleGetFocusState:completion:")

guard let method = class_getInstanceMethod(handlerClass, selector) else {
  print("unknown")
  exit(0)
}

typealias Completion = @convention(block) (AnyObject) -> Void
typealias Handler = @convention(c) (AnyObject, Selector, AnyObject, Completion) -> Void

let runHandler = unsafeBitCast(method_getImplementation(method), to: Handler.self)
let semaphore = DispatchSemaphore(value: 0)
var focusState = "unknown"

runHandler(handler, selector, intent) { response in
  switch response.value(forKey: "state") as? Int {
  case 1:
    focusState = "on"
  case 2:
    focusState = "off"
  default:
    focusState = "unknown"
  }

  semaphore.signal()
}

if semaphore.wait(timeout: .now() + 5) == .timedOut {
  print("unknown")
  exit(0)
}

print(focusState)
SWIFT
}

if [[ "$(dnd_state)" == "on" ]]; then
  exit 0
fi

if ! /usr/bin/open -Ra "$app_name"; then
  print -u2 -- "Could not find ${app_name}.app. Install Todoist or set TODOIST_APP_NAME."
  exit 1
fi

/usr/bin/open -a "$app_name"

/usr/bin/osascript <<APPLESCRIPT
tell application "$app_name"
  activate
end tell

delay 0.4

try
  tell application "System Events"
    if exists process "$app_name" then
      tell process "$app_name"
        set frontmost to true
        try
          if (count of windows) > 0 then
            perform action "AXRaise" of front window
          end if
        end try
      end tell
    end if
  end tell
end try
APPLESCRIPT
